# Azure AI Foundry project endpoint
FOUNDRY_PROJECT_ENDPOINT=https://wds-aif-001.services.ai.azure.com/api/projects/demo1
# Model deployment name (e.g. gpt-4o)
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-5.1
# Path to the skills folder (default: ./skills)
SKILLS_FOLDER=./skills
# Path to the memory folder (default: ./memory)
MEMORY_FOLDER=./memory
# Path to the checklists folder (default: ./checklists)
CHECKLISTS_FOLDER=./checklists
# Enable DevUI mode for local development (set to true to use the browser UI)
DEVUI=true
# DevUI server port (default: 8080)
DEVUI_PORT=8080
# DevUI server host (default: 127.0.0.1)
DEVUI_HOST=127.0.0.1
